# =============================================================================
# Fernandes Labs — Environment Variables
# =============================================================================
# Copy this file to ".env.local" for local development, OR set these in your
# hosting platform's dashboard (Vercel: Settings → Environment Variables).
#
# All variables MUST start with NEXT_PUBLIC_ so they're available in the
# browser (the tools run client-side).
#
# Lines starting with # are comments. Uncomment the lines below and fill in
# your values. Variables you leave commented out use safe defaults.
# =============================================================================

# ---- Site ------------------------------------------------------------------
# NEXT_PUBLIC_SITE_NAME="Fernandes Labs"
# NEXT_PUBLIC_SITE_DOMAIN="fernandeslabs.com"
# NEXT_PUBLIC_SITE_URL="https://fernandeslabs.com"
# NEXT_PUBLIC_SITE_DESCRIPTION="Free online tools for developers, designers, and marketers."
NEXT_PUBLIC_CONTACT_EMAIL="fernandeslabssupport@gmail.com"

# ---- Google AdSense (https://adsense.google.com) --------------------------
# Set these AFTER your AdSense application is approved.
# NEXT_PUBLIC_ADSENSE_ENABLED="true"
# NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-1234567890123456"
# NEXT_PUBLIC_ADSENSE_SLOT_HORIZONTAL="1234567890"
# NEXT_PUBLIC_ADSENSE_SLOT_VERTICAL="0987654321"
# NEXT_PUBLIC_ADSENSE_SLOT_FOOTER="1111111111"

# ---- Google Analytics 4 (https://analytics.google.com) --------------------
# Your GA4 Measurement ID (looks like G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ---- Google Search Console (https://search.google.com/search-console) -----
# The verification token (just the token part, not the full meta tag)
# NEXT_PUBLIC_SEARCH_CONSOLE_TOKEN="your-verification-token-here"

# ---- Crypto Donations (optional) ------------------------------------------
# NEXT_PUBLIC_CRYPTO_ENABLED="true"
# NEXT_PUBLIC_CRYPTO_BTC="bc1qyourbitcoinaddress"
# NEXT_PUBLIC_CRYPTO_ETH="0xyourethereumaddress"
# NEXT_PUBLIC_CRYPTO_USDC="0xyourusdcaddress"
# NEXT_PUBLIC_CRYPTO_SOL="yoursolanaaddress"

# ---- Affiliate Links (optional) -------------------------------------------
# Sign up for these free programs and paste your affiliate URLs:
#   Cloudflare: https://www.cloudflare.com/partners/
#   Namecheap:  https://www.namecheap.com/affiliates/
#   1Password:  https://1password.com/partnerships/
#   ProtonVPN:  https://protonvpn.com
#   Ahrefs:     https://ahrefs.com/affiliate
# NEXT_PUBLIC_AFFILIATE_ENABLED="true"
# NEXT_PUBLIC_AFF_HOSTING="https://cloudflare.com/?aff=YOURID"
# NEXT_PUBLIC_AFF_DOMAIN="https://namecheap.com/?aff=YOURID"
# NEXT_PUBLIC_AFF_VPN="https://protonvpn.com/?ref=YOURID"
# NEXT_PUBLIC_AFF_PASSWORD_MANAGER="https://1password.com/?ref=YOURID"
# NEXT_PUBLIC_AFF_SEO_TOOL="https://ahrefs.com/affiliate/YOURID"

# ---- Social Links (optional) ----------------------------------------------
# NEXT_PUBLIC_SOCIAL_GITHUB="https://github.com/FernandesLabs/Labs"
# NEXT_PUBLIC_SOCIAL_TWITTER="https://twitter.com/fernandeslabs"

# ---- Database (server-side only, NOT prefixed with NEXT_PUBLIC_) ----------
# This is set automatically by Vercel when you create a Postgres/SQLite db,
# or you can set it manually. For SQLite (default), use a file path.
DATABASE_URL="file:./db/custom.db"

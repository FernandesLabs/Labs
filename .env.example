# ──────────────────────────────────────────────────────────────────────────
# Fernandes Labs Tool Network — Environment Variables
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser (intentional —
# the tools run client-side and need to render ads/analytics).
# ──────────────────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────────────────
# SQLite database file (local). Prisma reads this.
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# Contact email shown in the footer, privacy policy, and terms.
NEXT_PUBLIC_CONTACT_EMAIL="fernandeslabssupport@gmail.com"

# ── Site identity ───────────────────────────────────────────────────────
# Used for canonical URLs, sitemap, OG metadata, and the footer.
NEXT_PUBLIC_SITE_NAME="Fernandes Labs"
NEXT_PUBLIC_SITE_DOMAIN="fernandeslabs.com"
NEXT_PUBLIC_SITE_URL="https://fernandeslabs.com"
NEXT_PUBLIC_SITE_DESCRIPTION="Free online tools for developers, designers, and marketers. No sign-up. No tracking. Works offline."

# ── Google AdSense ──────────────────────────────────────────────────────
# Apply at https://adsense.google.com. Set ENABLED=true once approved.
# The client ID (ca-pub-…) is injected into <head> for crawler verification.
# Create 3 ad units in AdSense (horizontal, vertical, footer) and paste the
# slot numbers below.
NEXT_PUBLIC_ADSENSE_ENABLED="true"
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-2766049026468980"
NEXT_PUBLIC_ADSENSE_SLOT_HORIZONTAL=""
NEXT_PUBLIC_ADSENSE_SLOT_VERTICAL=""
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=""

# ── Google Analytics 4 ──────────────────────────────────────────────────
# Works with any URL (including *.vercel.app) — no custom domain required.
# Create at https://analytics.google.com.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ── Google Search Console ───────────────────────────────────────────────
# Verify at https://search.google.com/search-console using the HTML meta tag
# method. Paste just the token (not the full tag).
NEXT_PUBLIC_SEARCH_CONSOLE_TOKEN=""

# ── Crypto donations (optional) ─────────────────────────────────────────
NEXT_PUBLIC_CRYPTO_ENABLED="true"
NEXT_PUBLIC_CRYPTO_BTC=""
NEXT_PUBLIC_CRYPTO_ETH=""
NEXT_PUBLIC_CRYPTO_USDC=""
NEXT_PUBLIC_CRYPTO_SOL=""

# ── Affiliate links (optional) ──────────────────────────────────────────
# Shown contextually per category in the affiliate-links component.
NEXT_PUBLIC_AFFILIATE_ENABLED="true"
NEXT_PUBLIC_AFF_HOSTING="https://cloudflare.com"
NEXT_PUBLIC_AFF_DOMAIN="https://namecheap.com"
NEXT_PUBLIC_AFF_VPN="https://protonvpn.com"
NEXT_PUBLIC_AFF_PASSWORD_MANAGER=""
NEXT_PUBLIC_AFF_SEO_TOOL=""

# ── Social links (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_SOCIAL_GITHUB="https://github.com/FernandesLabs/Labs"
NEXT_PUBLIC_SOCIAL_TWITTER=""
